# ============================================================
# Skales — Shared .gitignore (v3)
# Adds: _archive/ folder for manually set-aside items
# ============================================================

# ---------- Dependencies ----------
node_modules/
.pnp/
.pnp.js
.yarn/cache
.yarn/install-state.gz
vendor/
__pycache__/
*.pyc
.venv/
venv/

# ---------- Build outputs ----------
dist/
dist-electron/
out/
build/
.next/
.nuxt/
.expo/
.expo-shared/
android/build/
android/app/build/
android/.gradle/
android/.idea/
android/local.properties
android/app/release/
ios/Pods/
ios/build/
ios/*.xcworkspace/xcuserdata/
*.apk
*.aab
*.ipa
*.dmg
*.exe
*.AppImage
*.deb
*.rpm
*.pkg
release/
updates/
dist/release-artifacts/

# ---------- Electron-specific ----------
app-builds/
electron-builder.env

# ---------- Cowork BACKUP FOLDERS ----------
backups/
backup/
_backups/
_backup/
**/backups/
**/backup/
.backups/
.backup/

# ---------- Manual archive (items set aside from repo) ----------
_archive/
**/_archive/

# ---------- Cowork backup artifacts (file suffixes) ----------
*.backup
*.backup-*
*.bak
*.bak*
*-backup
*-backup.*
*.pre-*
*.pre-*.ts
*.pre-*.tsx
*.pre-*.js
*.pre-*.jsx
*.pre-*.json
*.pre-*.md
pre-*-backup
pre-*-backup/
*-pre-backup
*.orig
*.rej
*.tmp
*.tmp-*
*-old.*
*_old.*

# ---------- Reports / Audits (Cowork artefacts, stay local) ----------
*REPORT*.md
*report*.md
*Report*.md
*AUDIT*.md
*audit*.md
*Audit*.md
*HANDOVER*.md
*handover*.md
*Handover*.md
*SESSION*.md
*session*.md
*Session*.md
*COWORK*.md
*cowork*.md
*Cowork*.md
*SWEEP*.md
*sweep*.md
*Sweep*.md
*DIAGNOSTIC*.md
*diagnostic*.md
*MASTER*.md
*POST-*.md
*POSTAUDIT*.md
*POSTSWEEP*.md

# Whitelist canonical docs
!README.md
!CHANGELOG.md
!CONTRIBUTING.md
!LICENSE
!LICENSE.md
!ROADMAP.md
!CLAUDE.md
!SKILL.md
!STORE_LISTING.md
!PRIVACY_POLICY.md
!PROOF_OF_AUTHORSHIP.md
!INSTALL-WINDOWS.md
!INSTALL-MAC.md
!INSTALL-LINUX.md
!COMMERCIAL-LICENSE.md
!TERMS.md
!SECURITY.md
!**/SKILL.md
!docs/**/*.md

